# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ZALO_OA_ACCESS_TOKEN: Access token for Zalo Official Account API
ZALO_OA_ACCESS_TOKEN="YOUR_ZALO_OA_ACCESS_TOKEN"

# ZALO_OA_REFRESH_TOKEN: Used to get a new access token when it expires
ZALO_OA_REFRESH_TOKEN="YOUR_ZALO_OA_REFRESH_TOKEN"

# ZALO_APP_ID: Your Zalo App ID
ZALO_APP_ID="YOUR_ZALO_APP_ID"

# ZALO_APP_SECRET: Your Zalo App Secret
ZALO_APP_SECRET="YOUR_ZALO_APP_SECRET"

# FACEBOOK_PAGE_ID: Numeric page ID or page path
FACEBOOK_PAGE_ID="ngoisaohoangmai"

# FACEBOOK_PAGE_PATH: Public page path used for fallback links
FACEBOOK_PAGE_PATH="ngoisaohoangmai"

# FACEBOOK_PAGE_ACCESS_TOKEN: Page access token for Meta Graph API
FACEBOOK_PAGE_ACCESS_TOKEN="YOUR_FACEBOOK_PAGE_ACCESS_TOKEN"

VITE_FIREBASE_API_KEY="AIzaSyCuVbg7rKDNVld2esQN802_E-nNaDFCkKs"
VITE_FIREBASE_AUTH_DOMAIN="estore-54368.firebaseapp.com"
